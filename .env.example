# Backend Environment Variables
DATABASE_URL=postgresql://agroadb:agroadb_dev_password@localhost:5432/agroadb
REDIS_URL=redis://localhost:6379/0
SECRET_KEY=your_secret_key_here_change_in_production
# Opcional: criptografia de dados em repouso (32 bytes em base64 se usar esse módulo)
# ENCRYPTION_KEY=
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Environment
ENVIRONMENT=development

# Dados fictícios (MOCK_DEMO) após POST /investigations/{id}/enrich — só fora de produção.
# Em produção é sempre ignorado.
# ENABLE_INVESTIGATION_ENRICH_DEMO_SEED=true

# CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# External APIs (adicionar conforme necessário)
# INCRA_API_KEY=
# CAR_API_KEY=
# SERPAPI_KEY=

# Tribunais Estaduais (Web Scraping - não requer API keys)
ESAJ_ENABLED=true
PROJUDI_ENABLED=true

# Birôs de Crédito - Serasa Experian (Requer contrato comercial)
# SERASA_CLIENT_ID=seu_client_id_aqui
# SERASA_CLIENT_SECRET=seu_client_secret_aqui

# Birôs de Crédito - Boa Vista SCPC (Requer contrato comercial)
# BOAVISTA_CLIENT_ID=seu_client_id_aqui
# BOAVISTA_CLIENT_SECRET=seu_client_secret_aqui

# Frontend Environment Variables
VITE_API_URL=http://localhost:8000
VITE_APP_NAME=AgroADB
VITE_APP_VERSION=1.0.0

# --- Observabilidade (docker compose --profile obs: Tempo, Prometheus, Grafana, Alertmanager) ---
# Descomente para enviar traces OTLP da API e do Celery para o Tempo na rede Docker.
# OTEL_ENABLED=true
# OTEL_EXPORTER_OTLP_ENDPOINT=http://tempo:4318/v1/traces
# (OTEL_SERVICE_NAME é fixo no compose: agroadb-api no backend, agroadb-celery no worker.)
#
# Alertmanager (receptores Slack, PagerDuty, e-mail) — substitua pelos valores reais.
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
# PAGERDUTY_ROUTING_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# AM_EMAIL_TO=oncall@example.com
# AM_SMTP_SMARTHOST=smtp.example.com:587
# AM_SMTP_FROM=alertmanager@example.com
#
# Grafana (perfil obs) — não use admin/admin em produção
# GRAFANA_ADMIN_USER=admin@example.com
# GRAFANA_ADMIN_PASSWORD_FILE=./monitoring/secrets/grafana_admin_password
# GRAFANA_ROOT_URL=https://grafana.example.com
# GRAFANA_SECRET_KEY=gerar-string-longa-aleatoria
