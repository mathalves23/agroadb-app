# Production Environment Variables Template

# =================================
# APPLICATION
# =================================
ENVIRONMENT=production
PROJECT_NAME="AgroADB"
VERSION=1.0.0

# =================================
# DATABASE
# =================================
# PostgreSQL Connection
DATABASE_URL=postgresql+asyncpg://agroadb_user:CHANGE_THIS_PASSWORD@postgres:5432/agroadb_prod
# Para produção externa: postgresql+asyncpg://user:pass@host:5432/db

# =================================
# REDIS
# =================================
# Redis Connection (cache & celery broker)
REDIS_URL=redis://redis:6379/0
# Para produção externa: redis://host:6379/0

# =================================
# SECURITY
# =================================
# CRITICAL: Generate a strong secret key!
# Use: openssl rand -hex 32
SECRET_KEY=CHANGE_THIS_TO_A_VERY_LONG_RANDOM_STRING_MIN_32_CHARS

# JWT Configuration
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# =================================
# CORS
# =================================
# Allowed origins (comma-separated)
CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# =================================
# API CONFIGURATION
# =================================
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100
RATE_LIMIT_PER_MINUTE=60

# =================================
# SCRAPING
# =================================
SCRAPING_TIMEOUT=30
SCRAPING_MAX_RETRIES=3
SCRAPING_DELAY=1.0

# =================================
# EXTERNAL APIS (Optional)
# =================================
# Add your API keys here
INCRA_API_KEY=
CAR_API_KEY=
SERPAPI_KEY=
OPENAI_API_KEY=

# =================================
# MONITORING (Optional)
# =================================
# Sentry DSN for error tracking
SENTRY_DSN=

# =================================
# EMAIL (Optional - for notifications)
# =================================
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@agroadb.com

# =================================
# FRONTEND
# =================================
VITE_API_URL=https://api.yourdomain.com
VITE_APP_NAME=AgroADB
VITE_APP_VERSION=1.0.0

# =================================
# AWS S3 (Optional - for file storage)
# =================================
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_BUCKET_NAME=agroadb-storage

# =================================
# DATABASE BACKUP
# =================================
BACKUP_ENABLED=true
BACKUP_SCHEDULE="0 2 * * *"  # 2 AM daily
BACKUP_RETENTION_DAYS=30

# =================================
# LOGS
# =================================
LOG_LEVEL=INFO
LOG_FORMAT=json

# =================================
# CELERY
# =================================
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0
CELERY_TASK_TIME_LIMIT=1800  # 30 minutes
CELERY_TASK_SOFT_TIME_LIMIT=1500  # 25 minutes
