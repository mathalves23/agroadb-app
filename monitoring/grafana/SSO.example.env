# Exemplo para OAuth/OIDC genérico (Keycloak, Azure AD, Google, etc.)
# Copie as linhas necessárias para o .env do projecto ou para variáveis do orquestrador.
# Documentação: https://grafana.com/docs/grafana/latest/setup-grafana/configure-security/configure-authentication/generic-oauth/

# GF_AUTH_GENERIC_OAUTH_ENABLED=true
# GF_AUTH_GENERIC_OAUTH_NAME=OIDC
# GF_AUTH_GENERIC_OAUTH_ALLOW_SIGN_UP=true
# GF_AUTH_GENERIC_OAUTH_CLIENT_ID=your-client-id
# GF_AUTH_GENERIC_OAUTH_CLIENT_SECRET=your-client-secret
# GF_AUTH_GENERIC_OAUTH_SCOPES=openid email profile
# GF_AUTH_GENERIC_OAUTH_AUTH_URL=https://idp.example.com/oauth2/authorize
# GF_AUTH_GENERIC_OAUTH_TOKEN_URL=https://idp.example.com/oauth2/token
# GF_AUTH_GENERIC_OAUTH_API_URL=https://idp.example.com/oauth2/userinfo
# GF_SERVER_ROOT_URL=https://grafana.example.com

# Opcional: desactivar login local após validar SSO (cuidado com lock-out).
# GF_AUTH_DISABLE_LOGIN_FORM=true
