# Copiar para `monitoring/env.observability` (não versionar segredos) e ajustar.
# Docker Compose (perfil `obs`) carrega este ficheiro nos serviços que o referenciam.

# --- OpenTelemetry (API + Celery → Tempo OTLP HTTP) ---
OTEL_ENABLED=true
OTEL_EXPORTER_OTLP_ENDPOINT=http://tempo:4318/v1/traces
# OTEL_SERVICE_NAME é definido por serviço no docker-compose (agroadb-api / agroadb-celery).

# --- Alertmanager (expand-env no alertmanager.yml) ---
# Webhook: criar em Slack → Incoming Webhooks; colar aqui o URL completo (não versionar valores reais noutros ramos).
SLACK_WEBHOOK_URL=
PAGERDUTY_ROUTING_KEY=
AM_EMAIL_TO=oncall@example.com
AM_SMTP_SMARTHOST=localhost:25
AM_SMTP_FROM=alertmanager@agroadb.local
AM_SMTP_USER=
AM_SMTP_PASS=
