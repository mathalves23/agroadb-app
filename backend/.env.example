# =============================================================================
# AgroADB - Configuração de Ambiente
# =============================================================================

# -----------------------------------------------------------------------------
# Ambiente
# -----------------------------------------------------------------------------
ENVIRONMENT=development  # development, staging, production
PROJECT_NAME=AgroADB
VERSION=1.0.0

# -----------------------------------------------------------------------------
# Database (PostgreSQL)
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://agroadb:password@localhost:5432/agroadb

# -----------------------------------------------------------------------------
# Redis (Cache & Queue)
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0

# -----------------------------------------------------------------------------
# Security & JWT
# -----------------------------------------------------------------------------
SECRET_KEY=your-super-secret-key-change-this-in-production-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Encryption (Gerar com: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
ENCRYPTION_KEY=your-encryption-key-base64-format

# -----------------------------------------------------------------------------
# HTTPS (Produção)
# -----------------------------------------------------------------------------
FORCE_HTTPS=false  # true em produção
HTTPS_REDIRECT=false  # true em produção

# -----------------------------------------------------------------------------
# CORS (Produção: lista específica de origens)
# -----------------------------------------------------------------------------
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_METHODS=["GET","POST","PUT","DELETE","PATCH"]
CORS_MAX_AGE=600

# -----------------------------------------------------------------------------
# SMTP (Email)
# -----------------------------------------------------------------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@agroadb.com
SMTP_PASSWORD=your-smtp-password-or-app-password
SMTP_FROM=noreply@agroadb.com

# Alternativa: SendGrid
# SMTP_HOST=smtp.sendgrid.net
# SMTP_USER=apikey
# SMTP_PASSWORD=your-sendgrid-api-key

# Alternativa: AWS SES
# SMTP_HOST=email-smtp.us-east-1.amazonaws.com
# SMTP_USER=your-smtp-username
# SMTP_PASSWORD=your-smtp-password


# Frontend URL (para links em emails)
FRONTEND_URL=http://localhost:5173
SMTP_FROM_NAME=AgroADB Platform

# -----------------------------------------------------------------------------
# Rate Limiting
# -----------------------------------------------------------------------------
RATE_LIMIT_ANONYMOUS=20  # requisições por minuto
RATE_LIMIT_AUTHENTICATED=100
RATE_LIMIT_PREMIUM=500

# -----------------------------------------------------------------------------
# APIs Externas (Opcional)
# -----------------------------------------------------------------------------
# CAR
CAR_API_KEY=

# INCRA
INCRA_API_KEY=

# Receita Federal (se usar APIs pagas)
RECEITAWS_API_KEY=
CNPJA_API_KEY=

# Jusbrasil (Diários Oficiais)
JUSBRASIL_API_KEY=

# OpenAI (se usar análise com IA)
OPENAI_API_KEY=

# SerpAPI (para scraping avançado)
SERPAPI_KEY=

# -----------------------------------------------------------------------------
# Scraping Configuration
# -----------------------------------------------------------------------------
SCRAPING_TIMEOUT=30
SCRAPING_MAX_RETRIES=3
SCRAPING_DELAY=1.0

# -----------------------------------------------------------------------------
# Pagination
# -----------------------------------------------------------------------------
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100

# -----------------------------------------------------------------------------
# Monitoring (Opcional)
# -----------------------------------------------------------------------------
# Sentry (Error tracking)
SENTRY_DSN=

# Google Analytics
GA_MEASUREMENT_ID=

# -----------------------------------------------------------------------------
# AWS (Opcional - para S3, CloudWatch, etc)
# -----------------------------------------------------------------------------
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=

# -----------------------------------------------------------------------------
# Feature Flags
# -----------------------------------------------------------------------------
ENABLE_2FA=true
ENABLE_WEBHOOKS=true
ENABLE_EMAIL_NOTIFICATIONS=true
ENABLE_REPORTS=true

# -----------------------------------------------------------------------------
# LGPD
# -----------------------------------------------------------------------------
DPO_EMAIL=dpo@agroadb.com
PRIVACY_EMAIL=privacy@agroadb.com
SUPPORT_EMAIL=support@agroadb.com

# -----------------------------------------------------------------------------
# Notas Importantes
# -----------------------------------------------------------------------------
# 1. NUNCA commite este arquivo com valores reais!
# 2. Use .env para desenvolvimento local
# 3. Use variáveis de ambiente do servidor em produção
# 4. Gere SECRET_KEY e ENCRYPTION_KEY únicos e fortes
# 5. Configure SMTP antes de enviar emails
# 6. Em produção: FORCE_HTTPS=true, CORS restritivo
